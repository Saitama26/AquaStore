@model frontend.ViewModels.LandingViewModel
@{
    ViewData["Title"] = "AquaStore — Чистая вода для вашего дома";
    ViewData["HideHeaderSearch"] = true;

    string FilterTypeName(int ft) => ft switch
    {
        0 => "Кувшины",
        1 => "Под мойку",
        2 => "Обратный осмос",
        3 => "Магистральные",
        4 => "Насадки на кран",
        5 => "Картриджи",
        6 => "Фильтры для душа",
        7 => "Умягчители",
        _ => "—"
    };

    string FilterTypeDesc(int ft) => ft switch
    {
        0 => "Простое решение для чистой питьевой воды",
        1 => "Многоступенчатая очистка прямо из крана",
        2 => "Максимальная очистка от всех примесей",
        3 => "Защита труб и техники по всему дому",
        4 => "Компактная фильтрация без установки",
        5 => "Сменные модули для любых фильтров",
        6 => "Защита кожи и волос от хлора",
        7 => "Борьба с жёсткостью воды",
        _ => ""
    };

    string FilterTypeIcon(int ft) => ft switch
    {
        0 => "M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z",
        1 => "M3 6h18v2H3V6zm2 4h14v2H5v-2zm4 4h6v2H9v-2zm2 4h2v2h-2v-2z",
        2 => "M12 2l-5.5 9h11L12 2zm0 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z",
        3 => "M4 4h16v16H4V4zm2 2v12h12V6H6zm3 3h6v6H9V9z",
        4 => "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 14l-4-4h3V8h2v4h3l-4 4z",
        5 => "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.4-1.4L10 14.2l7.6-7.6L19 8l-9 9z",
        6 => "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8z",
        7 => "M19.4 10.3l-3.7-3.7-1.4 1.4 1 1L12 12.3l-3.3-3.3 1-1L8.3 6.6 4.6 10.3c-1.2 1.2-1.2 3.1 0 4.2l5 5c1.2 1.2 3.1 1.2 4.2 0l5.6-5.6c1.2-1.2 1.2-3.1 0-4.6z",
        _ => ""
    };

    var rootCategories = Model.Categories.Where(c => c.ParentCategoryId == null).OrderBy(c => c.Name).ToList();
    var spotlightCategoryNames = rootCategories.Select(c => c.Name).Take(5).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
}

<!-- ═══════ HERO ═══════ -->
<section class="hero">
    <div class="hero-content">
        <div class="hero-text">
            <div class="hero-kicker">
                <span class="hero-kicker-dot"></span>
                Подбор фильтра за 60 секунд
            </div>
            <h1 class="hero-title">
                <span class="hero-accent">Чистая вода</span>
                для вашего дома
            </h1>
            <p class="hero-subtitle">
                Фильтры для воды от ведущих производителей. 
                Подберём идеальное решение для вашей квартиры или дома — от кувшинов до систем обратного осмоса.
            </p>
            <div class="hero-trust-row">
                <span class="hero-trust-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L4 6v6c0 5.5 3.8 9.7 8 10 4.2-.3 8-4.5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg>
                    Проверенная сертификация
                </span>
                <span class="hero-trust-pill">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18"/><path d="M12 3v18"/></svg>
                    200+ конфигураций под задачу
                </span>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-number">@Model.TotalProductsCount+</span>
                    <span class="hero-stat-label">товаров в каталоге</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-number">@Model.Brands.Count</span>
                    <span class="hero-stat-label">брендов</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-number">@Model.Categories.Count</span>
                    <span class="hero-stat-label">категорий</span>
                </div>
            </div>
            <div class="hero-actions">
                <a href="/catalog" class="hero-btn hero-btn-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Перейти в каталог
                </a>
                <a href="#categories" class="hero-btn hero-btn-secondary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                    Подобрать фильтр
                </a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-orbit hero-orbit-1"></div>
            <div class="hero-orbit hero-orbit-2"></div>
            <div class="hero-image-glow"></div>
            <img src="/images/water-filter.svg" alt="Фильтр для воды" class="hero-image" />
            <div class="hero-floating-badges">
                <div class="hero-float-badge hfb-1">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Сертифицировано
                </div>
                <div class="hero-float-badge hfb-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Гарантия качества
                </div>
                <div class="hero-float-badge hfb-3">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Быстрая доставка
                </div>
            </div>
        </div>
    </div>

    <!-- Search on hero -->
    <form class="hero-search" method="get" action="/catalog" role="search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" name="searchTerm" placeholder="Поиск фильтров, картриджей, брендов..." aria-label="Поиск" />
        <button type="submit">Найти</button>
    </form>

    <div class="hero-marquee" aria-hidden="true">
        <div class="hero-marquee-track">
            <span>Океаническая свежесть в каждом глотке</span>
            <span>•</span>
            <span>Подбор по сценарию жизни</span>
            <span>•</span>
            <span>Доставка по Беларуси</span>
            <span>•</span>
            <span>Гарантия оригинальности</span>
            @foreach (var categoryName in spotlightCategoryNames)
            {
                <span>•</span>
                <span>@categoryName</span>
            }
        </div>
    </div>
</section>

<!-- ═══════ FILTER TYPE CATEGORIES ═══════ -->
<section class="landing-section" id="categories">
    <div class="section-header">
        <h2 class="section-title">Подберите фильтр по типу</h2>
        <p class="section-subtitle">Выберите тип фильтра, который подходит именно вам</p>
    </div>

    <div class="filter-type-tabs" id="filterTypeTabs">
        <button class="ft-tab active" data-ft="all">Все</button>
        @for (int i = 0; i <= 7; i++)
        {
            <button class="ft-tab" data-ft="@i">@FilterTypeName(i)</button>
        }
    </div>

    <div class="filter-type-grid">
        @for (int i = 0; i <= 7; i++)
        {
            <a href="/catalog?filterType=@i" class="ft-card" data-filter-type="@i">
                <div class="ft-card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="@FilterTypeIcon(i)"/>
                    </svg>
                </div>
                <div class="ft-card-info">
                    <h3>@FilterTypeName(i)</h3>
                    <p>@FilterTypeDesc(i)</p>
                </div>
                <span class="ft-card-arrow">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
            </a>
        }
    </div>
</section>

<!-- ═══════ WATER JOURNEY ═══════ -->
<section class="landing-section landing-journey">
    <div class="section-header">
        <h2 class="section-title">Ваш путь к чистой воде</h2>
        <p class="section-subtitle">От анализа задачи до стабильного вкуса воды — за три шага</p>
    </div>

    <div class="journey-grid">
        <article class="journey-card">
            <div class="journey-step">01</div>
            <h3>Сценарий потребления</h3>
            <p>Выберите, где нужна фильтрация: питьевая вода, кухня, душ или вся квартира.</p>
        </article>
        <article class="journey-card">
            <div class="journey-step">02</div>
            <h3>Точный формат системы</h3>
            <p>Подбираем решение по бюджету, ресурсу картриджей и требуемому уровню очистки.</p>
        </article>
        <article class="journey-card">
            <div class="journey-step">03</div>
            <h3>Долгосрочный комфорт</h3>
            <p>Оформляете заказ и спокойно пользуетесь системой с понятным графиком замены.</p>
        </article>
    </div>
</section>

<!-- ═══════ INSIGHTS ═══════ -->
<section class="landing-section landing-insights">
    <div class="section-header">
        <h2 class="section-title">Популярные сценарии выбора</h2>
        <p class="section-subtitle">Выберите вашу задачу и перейдите сразу к подходящему типу фильтра</p>
    </div>

    <div class="insights-grid">
        <a class="insight-card insight-card-featured" href="/catalog?filterType=2">
            <div class="insight-tag">Топ выбор</div>
            <h3>Максимальная очистка</h3>
            <p>Системы обратного осмоса для стабильного вкуса и глубокой фильтрации.</p>
            <span class="insight-link">К обратному осмосу</span>
        </a>
        <a class="insight-card" href="/catalog?filterType=1">
            <h3>Для кухни каждый день</h3>
            <p>Компактные системы под мойку с удобным обслуживанием.</p>
            <span class="insight-link">Смотреть модели</span>
        </a>
        <a class="insight-card" href="/catalog?filterType=3">
            <h3>Защита техники дома</h3>
            <p>Магистральные решения для труб, бойлеров и стиральных машин.</p>
            <span class="insight-link">Перейти в раздел</span>
        </a>
    </div>
</section>

<!-- ═══════ ADVANTAGES ═══════ -->
<section class="landing-section">
    <div class="section-header">
        <h2 class="section-title">Почему AquaStore?</h2>
        <p class="section-subtitle">Мы заботимся о качестве воды и вашем комфорте</p>
    </div>

    <div class="advantages-grid">
        <div class="advantage-card">
            <div class="advantage-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3>Оригинальная продукция</h3>
            <p>Только сертифицированные фильтры от официальных поставщиков</p>
        </div>
        <div class="advantage-card">
            <div class="advantage-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Гарантия качества</h3>
            <p>Возврат и обмен в течение 14 дней без вопросов</p>
        </div>
        <div class="advantage-card">
            <div class="advantage-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <h3>Доставка по всей Беларуси</h3>
            <p>Быстрая и бережная доставка прямо к вашей двери</p>
        </div>
        <div class="advantage-card">
            <div class="advantage-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3>Консультация специалистов</h3>
            <p>Поможем выбрать идеальный фильтр под ваши задачи</p>
        </div>
    </div>
</section>

<!-- ═══════ POPULAR PRODUCTS ═══════ -->
@if (Model.FeaturedProducts.Count > 0)
{
    <section class="landing-section">
        <div class="section-header">
            <h2 class="section-title">Популярные товары</h2>
            <a href="/catalog?sortBy=created&sortDescending=true" class="section-link">
                Смотреть все
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>

        @Html.CreateCards(Model.FeaturedProducts)
    </section>
}

<!-- ═══════ BRANDS ═══════ -->
@if (Model.Brands.Count > 0)
{
    <section class="landing-section">
        <div class="section-header">
            <h2 class="section-title">Наши бренды</h2>
            <p class="section-subtitle">Работаем с лучшими производителями фильтров для воды</p>
        </div>

        <div class="brands-grid">
            @foreach (var brand in Model.Brands.OrderBy(b => b.Name))
            {
                <a href="/catalog?brandId=@brand.Id" class="brand-card" title="@brand.Name">
                    @if (!string.IsNullOrEmpty(brand.LogoUrl))
                    {
                        <img src="@brand.LogoUrl" alt="@brand.Name" class="brand-logo" />
                    }
                    else
                    {
                        <span class="brand-name-text">@brand.Name</span>
                    }
                    @if (!string.IsNullOrEmpty(brand.Country))
                    {
                        <span class="brand-country">@brand.Country</span>
                    }
                </a>
            }
        </div>
    </section>
}

<!-- ═══════ CTA ═══════ -->
<section class="landing-cta">
    <div class="cta-content">
        <h2>Готовы к чистой воде?</h2>
        <p>Соберите систему, которая подходит именно вашему ритму жизни — от компактных решений до комплексной очистки дома</p>
        <div class="cta-actions">
            <a href="/catalog" class="hero-btn hero-btn-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Перейти в каталог
            </a>
            <a href="#categories" class="hero-btn hero-btn-secondary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/><path d="M2 12h20"/></svg>
                Подобрать по типу
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ── Filter type tab highlights ──
            const ftTabs = document.querySelectorAll(".ft-tab");
            const ftCards = document.querySelectorAll(".ft-card");

            ftTabs.forEach(tab => {
                tab.addEventListener("click", () => {
                    ftTabs.forEach(t => t.classList.remove("active"));
                    tab.classList.add("active");
                    const ft = tab.getAttribute("data-ft");

                    ftCards.forEach((card, i) => {
                        if (ft === "all" || card.getAttribute("data-filter-type") === ft) {
                            card.style.display = "";
                            // Re-trigger reveal with stagger
                            card.classList.remove("visible");
                            card.style.transitionDelay = `${i * 0.06}s`;
                            requestAnimationFrame(() => {
                                requestAnimationFrame(() => {
                                    card.classList.add("visible");
                                });
                            });
                        } else {
                            card.style.display = "none";
                        }
                    });
                });
            });

            // ── Smooth scroll for #categories link ──
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener("click", function(e) {
                    const target = document.querySelector(this.getAttribute("href"));
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: "smooth", block: "start" });
                    }
                });
            });

            // ── Scroll reveal with staggered delays ──
            function applyStagger(selector, parentSelector, delay) {
                const parents = parentSelector
                    ? document.querySelectorAll(parentSelector)
                    : [document];

                parents.forEach(parent => {
                    const items = parent.querySelectorAll(selector);
                    items.forEach((el, i) => {
                        el.style.transitionDelay = `${i * delay}s`;
                    });
                });
            }

            // Stagger child elements within their grid containers
            applyStagger(".ft-card", ".filter-type-grid", 0.06);
            applyStagger(".advantage-card", ".advantages-grid", 0.1);
            applyStagger(".brand-card", ".brands-grid", 0.05);
            applyStagger(".product-card", ".products-grid", 0.07);
            applyStagger(".journey-card", ".journey-grid", 0.12);
            applyStagger(".insight-card", ".insights-grid", 0.1);

            // Observer for revealing elements on scroll
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("visible");
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.08,
                rootMargin: "0px 0px -40px 0px"
            });

            // Observe all revealable elements
            const revealSelectors = [
                ".section-header",
                ".filter-type-tabs",
                ".ft-card",
                ".advantage-card",
                ".journey-card",
                ".insight-card",
                ".brand-card",
                ".product-card",
                ".landing-cta"
            ];

            document.querySelectorAll(revealSelectors.join(", ")).forEach(el => {
                revealObserver.observe(el);
            });

            // ── Respect prefers-reduced-motion ──
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
                document.querySelectorAll(revealSelectors.join(", ")).forEach(el => {
                    el.style.transition = "none";
                    el.classList.add("visible");
                });
            }
        });
    </script>
}
