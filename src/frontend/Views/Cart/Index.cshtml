@model frontend.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Корзина";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="cart-page">
    <div class="cart-content">
        <div class="cart-header">
            <h1>Корзина</h1>
            <span class="cart-count">@Model.TotalItems товар(ов)</span>
        </div>

        <div class="cart-list">
            @if (Model.Items.Count == 0)
            {
                <div class="cart-empty">
                    <p>Корзина пока пуста.</p>
                    <a href="/catalog" class="cart-empty-link">Перейти к покупкам</a>
                </div>
            }
            else
            {
                <div class="cart-select-all">
                    <label>
                        <input type="checkbox" id="selectAllCartItems" checked />
                        Выбрать все товары
                    </label>
                </div>
                foreach (var item in Model.Items)
                {
                    <div class="cart-item"
                         data-product-id="@item.ProductId"
                         data-quantity="@item.Quantity"
                         data-unit-price="@item.UnitPrice"
                         data-total-price="@item.TotalPrice">
                        <div class="cart-item-select">
                            <input type="checkbox" class="cart-item-checkbox" value="@item.ProductId" checked aria-label="Выбрать товар @item.ProductName" />
                        </div>
                        <div class="cart-item-image">
                            <img src="@(string.IsNullOrEmpty(item.ProductImageUrl) ? Url.Content("~/images/water-filter.svg") : item.ProductImageUrl)" alt="@item.ProductName" />
                        </div>
                        <div class="cart-item-info">
                            <a class="cart-item-title" href="/products/@item.ProductSlug">@item.ProductName</a>
                            <div class="cart-item-subtitle">Артикул: @item.ProductId</div>
                        </div>
                        <div class="cart-item-qty">
                            <button class="qty-btn qty-decrease" type="button" aria-label="Уменьшить количество">-</button>
                            <input class="qty-input" type="number" min="1" value="@item.Quantity" aria-label="Количество товара @item.ProductName" />
                            <button class="qty-btn qty-increase" type="button" aria-label="Увеличить количество">+</button>
                        </div>
                        <div class="cart-item-price">
                            <span class="current-price">@item.TotalPrice.ToString("N2") @Model.Currency</span>
                            <span class="unit-price">@item.UnitPrice.ToString("N2") @Model.Currency за шт.</span>
                        </div>
                        <button class="cart-item-remove" type="button" data-product-id="@item.ProductId" aria-label="Удалить">
                            ✕
                        </button>
                    </div>
                }
            }
        </div>
    </div>

    <aside class="cart-summary">
        <h2>Итого</h2>
        <div class="summary-row">
            <span id="selected-items-label">Товары, @Model.TotalItems шт.</span>
            <span id="selected-items-amount" data-currency="@Model.Currency">@Model.TotalAmount.ToString("N2") @Model.Currency</span>
        </div>
        <div class="summary-row total">
            <span>Итого</span>
            <span id="selected-total-amount" data-currency="@Model.Currency">@Model.TotalAmount.ToString("N2") @Model.Currency</span>
        </div>
        @if (Model.Items.Count > 0)
        {
            <button class="checkout-button" id="checkoutSelectedButton" type="button">Оформить выбранное</button>
        }
        else
        {
            <button class="checkout-button" type="button" disabled>Оформить заказ</button>
        }
        <label class="summary-agreement">
            <input type="checkbox" />
            Соглашаюсь с правилами использования
        </label>
    </aside>
</div>

@section Scripts {
    <script>
        const buildCheckoutUrl = () => {
            const selected = Array.from(document.querySelectorAll(".cart-item-checkbox:checked"))
                .map((checkbox) => checkbox.value)
                .filter((value) => !!value);

            if (selected.length === 0) {
                showNotification("Выберите хотя бы один товар.", "info");
                return null;
            }

            const params = new URLSearchParams();
            selected.forEach((id) => params.append("productIds", id));
            return `/Cart/Checkout?${params.toString()}`;
        };

        const selectAll = document.getElementById("selectAllCartItems");
        const itemCheckboxes = document.querySelectorAll(".cart-item-checkbox");
        const checkoutButton = document.getElementById("checkoutSelectedButton");
        const selectedItemsLabel = document.getElementById("selected-items-label");
        const selectedItemsAmount = document.getElementById("selected-items-amount");
        const selectedTotalAmount = document.getElementById("selected-total-amount");

        const updateSelectedSummary = () => {
            if (!selectedItemsLabel || !selectedItemsAmount || !selectedTotalAmount) {
                return;
            }

            let itemsCount = 0;
            let amount = 0;

            itemCheckboxes.forEach((checkbox) => {
                if (!checkbox.checked) {
                    return;
                }

                const cartItem = checkbox.closest(".cart-item");
                if (!cartItem) {
                    return;
                }

                itemsCount += parseInt(cartItem.dataset.quantity || "0", 10);
                amount += parseFloat(cartItem.dataset.totalPrice || "0");
            });

            const currency = selectedItemsAmount.dataset.currency || "";
            const formattedAmount = `${amount.toLocaleString("ru-RU", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`.trim();

            selectedItemsLabel.textContent = `Товары, ${itemsCount} шт.`;
            selectedItemsAmount.textContent = formattedAmount;
            selectedTotalAmount.textContent = formattedAmount;
        };

        const updateHeaderItemCount = () => {
            const headerCount = document.querySelector(".cart-header .cart-count");
            if (!headerCount) {
                return;
            }

            const totalItems = Array.from(document.querySelectorAll(".cart-item"))
                .map((item) => parseInt(item.dataset.quantity || "0", 10))
                .reduce((sum, qty) => sum + qty, 0);

            headerCount.textContent = `${totalItems} товар(ов)`;
        };

        const syncRowTotal = (cartItem, quantity) => {
            const unitPrice = parseFloat(cartItem.dataset.unitPrice || "0");
            const total = unitPrice * quantity;
            cartItem.dataset.quantity = `${quantity}`;
            cartItem.dataset.totalPrice = `${total}`;

            const currentPrice = cartItem.querySelector(".current-price");
            const currency = selectedItemsAmount?.dataset.currency || "";
            if (currentPrice) {
                currentPrice.textContent = `${total.toLocaleString("ru-RU", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`.trim();
            }
        };

        const changeQuantity = async (cartItem, nextQuantity) => {
            const productId = cartItem.dataset.productId;
            if (!productId) {
                return false;
            }

            const quantity = Math.max(1, nextQuantity);
            const response = await fetch(`/Cart/UpdateQuantity?productId=${productId}&quantity=${quantity}`, {
                method: "POST"
            });

            if (!response.ok) {
                let errorMessage = "Не удалось обновить количество товара.";
                try {
                    const data = await response.json();
                    if (data?.message) {
                        errorMessage = data.message;
                    }
                } catch {
                    // ignore parse errors
                }

                showNotification(errorMessage, "error");
                return false;
            }

            syncRowTotal(cartItem, quantity);
            updateHeaderItemCount();
            updateSelectedSummary();
            updateCartCount();
            return true;
        };

        if (selectAll && itemCheckboxes.length > 0) {
            selectAll.addEventListener("change", () => {
                itemCheckboxes.forEach((checkbox) => {
                    checkbox.checked = selectAll.checked;
                });
                updateSelectedSummary();
            });

            itemCheckboxes.forEach((checkbox) => {
                checkbox.addEventListener("change", () => {
                    const checkedCount = Array.from(itemCheckboxes).filter((item) => item.checked).length;
                    selectAll.checked = checkedCount === itemCheckboxes.length;
                    updateSelectedSummary();
                });
            });

            updateSelectedSummary();
        }

        if (checkoutButton) {
            checkoutButton.addEventListener("click", () => {
                const checkoutUrl = buildCheckoutUrl();
                if (checkoutUrl) {
                    window.location.href = checkoutUrl;
                }
            });
        }

        document.querySelectorAll(".cart-item").forEach((cartItem) => {
            const qtyInput = cartItem.querySelector(".qty-input");
            const decreaseBtn = cartItem.querySelector(".qty-decrease");
            const increaseBtn = cartItem.querySelector(".qty-increase");

            if (!(qtyInput instanceof HTMLInputElement) || !decreaseBtn || !increaseBtn) {
                return;
            }

            const applyQuantity = async (rawValue) => {
                const previous = parseInt(cartItem.dataset.quantity || "1", 10) || 1;
                const parsed = parseInt(rawValue, 10);
                const requested = Number.isNaN(parsed) ? previous : Math.max(1, parsed);
                qtyInput.value = `${requested}`;

                if (requested === previous) {
                    return;
                }

                const updated = await changeQuantity(cartItem, requested);
                if (!updated) {
                    qtyInput.value = `${previous}`;
                }
            };

            decreaseBtn.addEventListener("click", async () => {
                const current = parseInt(qtyInput.value || cartItem.dataset.quantity || "1", 10);
                await applyQuantity(`${Math.max(1, current - 1)}`);
            });

            increaseBtn.addEventListener("click", async () => {
                const current = parseInt(qtyInput.value || cartItem.dataset.quantity || "1", 10);
                await applyQuantity(`${Math.max(1, current + 1)}`);
            });

            qtyInput.addEventListener("change", async () => {
                await applyQuantity(qtyInput.value);
            });

            qtyInput.addEventListener("blur", async () => {
                await applyQuantity(qtyInput.value);
            });
        });

        document.querySelectorAll(".cart-item-remove").forEach((button) => {
            button.addEventListener("click", async () => {
                const productId = button.dataset.productId;
                if (!productId) return;

                const response = await fetch(`/Cart/Remove?productId=${productId}`, { method: "DELETE" });
                if (response.ok) {
                    updateCartCount();
                    location.reload();
                } else {
                    alert("Не удалось удалить товар из корзины.");
                }
            });
        });
    </script>
}

