@model frontend.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="account-wrapper">
    <div class="account-ocean-bg" aria-hidden="true">
        <span class="sun-ray sun-ray-1"></span>
        <span class="sun-ray sun-ray-2"></span>
        <span class="bubble bubble-1"></span>
        <span class="bubble bubble-2"></span>
        <span class="bubble bubble-3"></span>
        <span class="bubble bubble-4"></span>
        <span class="bubble bubble-5"></span>
        <span class="bubble bubble-6"></span>
        <span class="bubble bubble-7"></span>
        <span class="bubble bubble-8"></span>
    </div>
    <div class="account-card account-card-wide">
        <div class="account-avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.4 0-8 2-8 4.5V21h16v-2.5C20 16 16.4 14 12 14Z"></path>
            </svg>
        </div>
        <h1>Регистрация</h1>
        <p class="account-subtitle">Создайте аккаунт и получите доступ к заказам, корзине и отзывам.</p>

        @if (ViewData["Success"] is string successMessage)
        {
            <div class="form-success">@successMessage</div>
        }

        <p class="account-note">После отправки формы мы пришлём код подтверждения на email.</p>

        <form asp-action="Register" asp-controller="Account" method="post" class="account-form">
            <div asp-validation-summary="ModelOnly" class="form-error"></div>

            <label asp-for="FirstName" class="field-label">Имя</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.4 0-8 2-8 4.5V21h16v-2.5C20 16 16.4 14 12 14Z"></path>
                    </svg>
                </span>
                <input asp-for="FirstName" type="text" autocomplete="given-name" />
            </div>
            <span asp-validation-for="FirstName" class="field-error"></span>

            <label asp-for="LastName" class="field-label">Фамилия</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.4 0-8 2-8 4.5V21h16v-2.5C20 16 16.4 14 12 14Z"></path>
                    </svg>
                </span>
                <input asp-for="LastName" type="text" autocomplete="family-name" />
            </div>
            <span asp-validation-for="LastName" class="field-error"></span>

            <label asp-for="Email" class="field-label">Email</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm0 2 8 5 8-5"></path>
                    </svg>
                </span>
                <input asp-for="Email" type="email" autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="field-error"></span>

            <label asp-for="Password" class="field-label">Пароль</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 11V8a5 5 0 0 1 10 0v3m-9 0h8a2 2 0 0 1 2 2v7H6v-7a2 2 0 0 1 2-2Z"></path>
                    </svg>
                </span>
                <input asp-for="Password" type="password" autocomplete="new-password" />
            </div>
            <span asp-validation-for="Password" class="field-error"></span>

            <label asp-for="ConfirmPassword" class="field-label">Подтверждение пароля</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 11V8a5 5 0 0 1 10 0v3m-9 0h8a2 2 0 0 1 2 2v7H6v-7a2 2 0 0 1 2-2Z"></path>
                    </svg>
                </span>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>

            <label asp-for="Phone" class="field-label">Телефон (необязательно)</label>
            <div class="input-with-icon">
                <span class="input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M6.6 2h2.8a1 1 0 0 1 1 .8l.6 2.8a1 1 0 0 1-.3.9L9.3 8.1a15 15 0 0 0 6.6 6.6l1.6-1.4a1 1 0 0 1 .9-.3l2.8.6a1 1 0 0 1 .8 1v2.8a1 1 0 0 1-.9 1A17 17 0 0 1 5.6 2.9a1 1 0 0 1 1-.9Z"></path>
                    </svg>
                </span>
                <input asp-for="Phone" type="tel" autocomplete="tel" />
            </div>
            <span asp-validation-for="Phone" class="field-error"></span>

            <button type="submit" class="submit-button">Создать аккаунт</button>
        </form>

        <div class="account-footer">
            Уже есть аккаунт?
            <a href="/account/login">Войти</a>
        </div>
    </div>
</div>