@using System.Text.Json
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - frontend</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/frontend.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="paper-cut-background" aria-hidden="true">
        <svg class="paper-cut-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <!-- Combined outer + inner shadow for paper-cut depth -->
                <filter id="paperCut" x="-10%" y="-10%" width="120%" height="120%">
                    <!-- Outer drop shadow (cast onto layer below) -->
                    <feGaussianBlur in="SourceAlpha" stdDeviation="7" result="outerBlur"/>
                    <feOffset in="outerBlur" dx="-4" dy="6" result="outerShifted"/>
                    <feFlood flood-color="#0a1528" flood-opacity="0.30" result="outerColor"/>
                    <feComposite in="outerColor" in2="outerShifted" operator="in" result="outerShadow"/>

                    <!-- Inner shadow (inset along wave edge) -->
                    <feComponentTransfer in="SourceAlpha" result="invertedAlpha">
                        <feFuncA type="table" tableValues="1 0"/>
                    </feComponentTransfer>
                    <feGaussianBlur in="invertedAlpha" stdDeviation="5" result="innerBlur"/>
                    <feOffset in="innerBlur" dx="3" dy="4" result="innerShifted"/>
                    <feFlood flood-color="#000000" flood-opacity="0.22" result="innerColor"/>
                    <feComposite in="innerColor" in2="innerShifted" operator="in" result="innerShadow"/>
                    <feComposite in="innerShadow" in2="SourceGraphic" operator="atop" result="shapeWithInner"/>

                    <!-- Merge: shadow behind, shape with inner shadow on top -->
                    <feMerge>
                        <feMergeNode in="outerShadow"/>
                        <feMergeNode in="shapeWithInner"/>
                    </feMerge>
                </filter>
            </defs>

            <!-- Layer 1 — lightest -->
            <path class="pc-wave-1" filter="url(#paperCut)"
                  d="M0,560 C60,520 140,460 250,400 C350,345 340,300 420,250
                     C500,200 540,230 620,175 C700,120 740,65 830,25
                     C900,-5 950,0 1020,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 2 -->
            <path class="pc-wave-2" filter="url(#paperCut)"
                  d="M0,640 C80,600 170,545 290,475 C400,410 380,360 470,300
                     C560,245 600,275 690,220 C775,165 820,105 920,55
                     C1010,10 1050,0 1120,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 3 -->
            <path class="pc-wave-3" filter="url(#paperCut)"
                  d="M0,715 C100,675 200,625 320,555 C440,485 410,435 520,370
                     C625,305 660,335 755,275 C845,220 890,155 990,90
                     C1080,35 1130,0 1200,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 4 -->
            <path class="pc-wave-4" filter="url(#paperCut)"
                  d="M0,775 C120,745 230,700 365,630 C500,555 470,505 575,440
                     C680,375 710,400 805,340 C900,280 940,205 1055,135
                     C1160,65 1200,15 1285,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 5 -->
            <path class="pc-wave-5" filter="url(#paperCut)"
                  d="M0,835 C140,805 260,765 405,700 C550,630 520,575 630,510
                     C740,445 770,465 860,400 C950,340 990,260 1115,175
                     C1230,95 1270,35 1355,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 6 -->
            <path class="pc-wave-6" filter="url(#paperCut)"
                  d="M0,885 C160,865 290,830 445,770 C600,705 570,650 690,580
                     C810,510 840,535 935,470 C1025,405 1065,315 1185,225
                     C1300,140 1340,55 1415,0 L1440,0 L1440,900 L0,900Z"/>

            <!-- Layer 7 — darkest -->
            <path class="pc-wave-7" filter="url(#paperCut)"
                  d="M0,930 C180,910 320,885 490,825 C660,760 630,710 755,645
                     C880,575 910,595 1005,530 C1095,470 1140,375 1260,280
                     C1375,185 1400,80 1440,35 L1440,900 L0,900Z"/>
        </svg>
    </div>

    <div class="wrapper">
        <header id="header-container" class="header header-container">
            <div class="logo-container">
                <a href="/" class="logo-link">
                    <span class="logo-text">AquaStore</span>
                    <img src="~/images/water-filter.svg" alt="Фильтры для воды" class="header-photo" />
                </a>
            </div>

            @if (!(ViewData["HideBurger"] as bool? ?? false))
            {
                <button type="button" class="burger-button" aria-label="Открыть меню" aria-expanded="false" aria-controls="navDrawer">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            }

            <nav class="menu-container">
                @if (!(ViewData["HideCatalogLink"] as bool? ?? false))
                {
                    <a href="/catalog" class="nav-catalog-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        Каталог
                    </a>
                }
            </nav>

            @if (!(ViewData["HideHeaderSearch"] as bool? ?? false))
            {
                <form class="search-container" role="search" method="get" action="/catalog">
                    <input type="text"
                           name="searchTerm"
                           value="@(ViewData["SearchTerm"] as string ?? string.Empty)"
                           placeholder="Поиск по каталогу"
                           aria-label="Поиск" />
                    <button type="submit" class="search-button" aria-label="Найти">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M21 20.3 16.7 16a7 7 0 1 0-1.4 1.4L19.6 21 21 20.3ZM5 10a5 5 0 1 1 10 0 5 5 0 0 1-10 0Z" />
                        </svg>
                    </button>
                </form>
            }

            @if (!(ViewData["HideAuthButtons"] as bool? ?? false))
            {
                <div class="authorization-container">
                    @{
                        if (User?.Identity?.IsAuthenticated == true)
                        {
                            <div class="authorization-buttons-container">
                                <a href="/Account/Profile" class="profile-button icon-link">
                                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.4 0-8 2-8 4.5V21h16v-2.5C20 16 16.4 14 12 14Z" />
                                    </svg>
                                    Профиль
                                </a>
                                <a href="/Cart" class="cart-button icon-link">
                                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path d="M7 18a2 2 0 1 0 2 2 2 2 0 0 0-2-2Zm10 0a2 2 0 1 0 2 2 2 2 0 0 0-2-2ZM6.2 6h13.6l-1.2 6H8.1L6.2 6Zm-2.7-2H2v2h1.2l2.3 9.6a2 2 0 0 0 2 1.4h10.6a2 2 0 0 0 2-1.6L22 6a2 2 0 0 0-2-2H5.1L4.6 2.8A2 2 0 0 0 2.7 2H1v2h2.5Z" />
                                    </svg>
                                    Корзина
                                    <span class="cart-button-count is-hidden" aria-label="Количество товаров в корзине">0</span>
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="authorization-buttons-container">
                                <a href="/Account/Login" class="login-button">Вход</a>
                                <a href="/Account/Register" class="register-button">Регистрация</a>
                            </div>
                        }
                    }
                </div>
            }
        </header>

        <main role="main" id="main-container" class="main main-container">
            @RenderBody()
        </main>
    </div>

    @await Component.InvokeAsync("NavigationMenu")




    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (TempData["ToastMessage"] is string toastMessage)
    {
        var toastType = TempData["ToastType"] as string ?? "info";
        var toastMessageJson = JsonSerializer.Serialize(toastMessage);
        var toastTypeJson = JsonSerializer.Serialize(toastType);
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                showNotification(@Html.Raw(toastMessageJson), @Html.Raw(toastTypeJson));
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
